{
  "extends": ["@electron-toolkit/tsconfig/tsconfig.web.json", "./tsconfig.base.json"],
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/shared/**/*",
    "src/main/**/*"
  ],
  "exclude": [
    "src/main/index.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx"
  }
}
